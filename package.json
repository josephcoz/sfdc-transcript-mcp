{
  "name": "sfdc-transcript-mcp",
  "version": "0.1.0",
  "description": "A local MCP server that turns meeting transcripts into human-confirmed Salesforce field updates.",
  "type": "module",
  "bin": {
    "sfdc-transcript-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "npm run build && mcpb pack"
  },
  "keywords": [
    "mcp",
    "salesforce",
    "model-context-protocol",
    "crm"
  ],
  "author": "Joe Cosby-Johnson",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "env-paths": "^4.0.0",
    "gray-matter": "^4.0.3",
    "jsforce": "^3.10.15",
    "open": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}

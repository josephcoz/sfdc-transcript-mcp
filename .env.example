# Consumer Key (Client ID) of your Salesforce External Client App (PKCE / public client)
SF_CLIENT_ID=

# Optional override login host, e.g. your My Domain (https://acme.my.salesforce.com).
# Leave blank to let connect_salesforce's "environment" arg choose sandbox vs production.
SF_LOGIN_HOST=

# Absolute path to your field allow-list JSON (see config/field-allowlist.example.json)
SF_ALLOWLIST_PATH=

# Optional: set to 1 for verbose stderr debug logging
SFDC_MCP_DEBUG=

# Consumer Key (Client ID) of your Salesforce External Client App (PKCE / public client)
SF_CLIENT_ID=

# Default login host. Sandbox by default; use https://login.salesforce.com for production,
# or your My Domain host (e.g. https://acme.my.salesforce.com).
SF_LOGIN_HOST=https://test.salesforce.com

# Absolute path to your field allow-list JSON (see config/field-allowlist.example.json)
SF_ALLOWLIST_PATH=

# Optional: set to 1 for verbose stderr debug logging
SFDC_MCP_DEBUG=

# All of these are OPTIONAL. The server runs with NONE of them set — it ships a
# bundled public OAuth client and discovers fields automatically. You do not need
# a consumer key or an allow-list.

# Optional: use your OWN Salesforce OAuth app instead of the bundled one.
SF_CLIENT_ID=

# Optional: override the login host (e.g. a My Domain https://acme.my.salesforce.com).
SF_LOGIN_HOST=

# Optional: override the OAuth redirect URI (must match your app's registered callback).
SF_REDIRECT_URI=

# Optional: set to 1 for verbose stderr debug logging.
SFDC_MCP_DEBUG=
